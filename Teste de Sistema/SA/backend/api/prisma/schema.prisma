generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id       Int     @id @default(autoincrement())
  nome     String  @db.VarChar(100)
  email    String  @unique @db.VarChar(100)
  senha    String  @db.VarChar(255)
  telefone String? @db.VarChar(20)
  criadoEm DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")
  motos         Moto[]

  @@map("usuarios")
}

model Moto {
  id            Int      @id @default(autoincrement())
  marca         String   @db.VarChar(50)
  modelo        String   @db.VarChar(100)
  categoria     String   @default("Street") @db.VarChar(50)
  ano           Int
  cor           String?  @db.VarChar(30)
  preco         Decimal  @db.Decimal(10, 2)
  descricao     String?  @db.Text
  quilometragem Int      @default(0)
  cilindradas   Int      @default(1)
  imagem        String?  @db.Text
  destaque      Boolean  @default(false)
  criadoEm      DateTime @default(now()) @map("criado_em")
  atualizadoEm  DateTime @updatedAt @map("atualizado_em")
  criadorId     Int?     @map("criador_id")
  criador       Usuario? @relation(fields: [criadorId], references: [id], onDelete: SetNull)

  @@unique([marca, modelo], map: "marca_modelo_unique")
  @@index([criadorId])
  @@map("motos")
}
